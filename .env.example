# Copy this file to .env and fill in real values. Never commit .env to git.

# Server
PORT=3000

# Owner email (where contact form submissions are sent)
OWNER_EMAIL=jesusmachen@gmail.com

# SMTP credentials for sending email.
# For Gmail, create an "App Password" at https://myaccount.google.com/apppasswords
# (requires 2FA enabled on the Google account).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sending-email@gmail.com
SMTP_PASS=your-app-password-here

# Google reCAPTCHA v2 keys
# Get keys at https://www.google.com/recaptcha/admin/create
# Choose "reCAPTCHA v2" -> "I'm not a robot" Checkbox
RECAPTCHA_SITE_KEY=your-site-key-here
RECAPTCHA_SECRET_KEY=your-secret-key-here
